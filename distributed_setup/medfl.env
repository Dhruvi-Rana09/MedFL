# ═══════════════════════════════════════════════════════════════════════════
#  MedFL — Distributed Tailscale Configuration
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Install Tailscale on all 5 laptops.
# 2. Find the Tailscale IP (starts with 100.x.x.x) of each laptop.
# 3. Enter those IPs below.
# 4. Copy this exact file to all 5 laptops before running docker compose.

# Device 1: Member running Auth Service
AUTH_IP=10.28.79.214

# Device 2: Member running Orchestrator
ORCHESTRATOR_IP=10.28.79.243

# Device 3: Member running Aggregation
AGGREGATOR_IP=10.28.79.243

# Device 4: Member running Monitoring (Dashboard)
MONITORING_IP=10.28.79.127

# Device 5: Member running Model Storage (MinIO)
STORAGE_IP=10.28.79.214

# ── Dynamic Service URLs (DO NOT EDIT THESE) ──
AUTH_URL=http://${AUTH_IP}:8001
ORCHESTRATOR_URL=http://${ORCHESTRATOR_IP}:8002
ORCHESTRATOR_GRPC=${ORCHESTRATOR_IP}:50051
AGG_URL=http://${AGGREGATOR_IP}:8003
MONITORING_URL=http://${MONITORING_IP}:8004
MODEL_STORAGE_URL=http://${STORAGE_IP}:8005
MINIO_ENDPOINT=${STORAGE_IP}:9000

# ── Universal Security and Config ──
ENCRYPTION_KEY=FSRmbNxUQ4mDE9RmDW8ZOnOKyg5CvQ_TG7V6FH08vGg=
LOCAL_EPOCHS=2
BATCH_SIZE=32
LEARNING_RATE=0.01
FEDPROX_MU=0.01
DP_EPSILON=inf
DP_DELTA=1e-5
DP_MAX_GRAD_NORM=1.0
N_CLASSES=10
AGGREGATION_ALGORITHM=fedprox
